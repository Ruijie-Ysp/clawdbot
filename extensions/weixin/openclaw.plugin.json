{
  "id": "weixin",
  "name": "Weixin",
  "description": "Weixin channel plugin with multi-account QR onboarding and local management page.",
  "channels": ["weixin"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string"
      },
      "enabled": {
        "type": "boolean"
      },
      "baseUrl": {
        "type": "string"
      },
      "cdnBaseUrl": {
        "type": "string"
      },
      "routeTag": {
        "type": "number"
      },
      "logUploadUrl": {
        "type": "string"
      },
      "accounts": {
        "type": "object"
      },
      "demoService": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "bind": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "restartCommand": {
            "type": "string"
          }
        }
      }
    }
  }
}
